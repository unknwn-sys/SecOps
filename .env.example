# ============================================================================
# Offensive Security Portal - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your specific values
# Do NOT commit .env to version control (includes secrets)
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Node.js Environment
NODE_ENV=production

# Server Port (Pi can use any port, 3000 is recommended)
PORT=3000
HOST=0.0.0.0

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Default admin username for local authentication
ADMIN_USERNAME=admin

# Admin password hash (use bcrypt)
# Generate with: openssl passwd -bcrypt -quiet <<< "YourPassword"
# Or use Node: require('bcryptjs').hashSync('password', 10)
ADMIN_PASSWORD_HASH=$2b$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcg7b3XeKeUxWdeS86E12dS7rBm

# JWT Secret (min 32 characters, random string)
JWT_SECRET=your-super-secret-random-key-minimum-32-characters-here-change-this

# Cookie Secret (can be same as JWT_SECRET)
COOKIE_SECRET=your-super-secret-random-key-minimum-32-characters-here-change-this

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (Development/Testing)
# DATABASE_URL=file:./data/dev.db

# MySQL (Production on RPi with remote DB)
DATABASE_URL=mysql://app_user:Strong_Database_Password_Here@192.168.1.50:3306/offensive_security

# ============================================================================
# HARDWARE UART CONFIGURATION
# ============================================================================

# Serial port for ESP32-S3 communication
# Common values:
# - /dev/ttyUSB0 (most common)
# - /dev/ttyUSB1 (if multiple USB serial devices)
# - /dev/ttyAMA0 (GPIO serial on RPi - if using GPIO pins)
UART_PORT=/dev/ttyUSB0

# UART Baud Rate (must match ESP32 firmware)
UART_BAUDRATE=9600

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# OPTIONAL: OAuth2 Integration (Legacy)
# ============================================================================
# If not using local auth, you can configure OAuth2 server
# Leave empty to disable OAuth and use local auth only

VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ============================================================================
# OPTIONAL: AWS S3 Integration (For future payload storage)
# ============================================================================

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. Change ADMIN_PASSWORD_HASH to a secure hash
# 2. Use strong JWT_SECRET (32+ chars, random)
# 3. For production RPi, use HTTPS with valid certificates
# 4. Restrict network access with firewall rules
# 5. Keep all credentials in .env (git-ignored)
# 6. Enable SSH key authentication and disable passwords
# 7. Regular security audits and log reviews
# ============================================================================

# ============================================
# If you want to keep OAuth support alongside JWT auth, set these:
# Leave empty to disable OAuth completely

# OAuth server URL (e.g., Manus OAuth server)
OAUTH_SERVER_URL=

# OAuth portal URL for redirect
VITE_OAUTH_PORTAL_URL=

# Owner's OpenID from OAuth provider
OWNER_OPEN_ID=

# ============================================
# OPTIONAL: API INTEGRATIONS
# ============================================

# Forge API (if applicable)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Enable debug logging (development only)
DEBUG=false

# Enable TypeScript source maps
SOURCE_MAP=true

# ============================================
# NOTES
# ============================================
# 1. NEVER commit this file to version control
# 2. Use different credentials for development, staging, and production
# 3. Store sensitive values in a secrets manager (not in git)
# 4. Rotate JWT_SECRET periodically in production
# 5. Change default admin password immediately after setup
# 6. Use strong, unique passwords (min 16 characters recommended)
# 7. For Raspberry Pi deployment, set NODE_ENV=production
# 8. Database backups are CRITICAL - implement automated backups
# 9. Monitor activity logs regularly for suspicious behavior
# 10. Keep all software dependencies updated
